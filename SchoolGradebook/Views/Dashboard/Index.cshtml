@model IEnumerable<dynamic>

<div class="container">
    <h2>Academic Dashboard</h2>
    <hr />
    
    <table class="table table-striped">
        <thead class="table-dark">
        <tr>
            <th>Student Name</th>
            <th>Average Grade</th>
            <th>Absences</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Name</td>
                <td>@item.Average.ToString("F2")</td>
                <td>
                    @* Display a red badge if absences exceed 5, otherwise use a blue badge *@
                    <span class="badge @(item.AbsenceCount > 5 ? "bg-danger" : "bg-primary")">
                        @item.AbsenceCount
                    </span>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>