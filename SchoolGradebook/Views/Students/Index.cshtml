@model IEnumerable<SchoolGradebook.DTOs.StudentDTO>

<div class="container">
    <h2>Students</h2>
    
    <form asp-action="Index" method="get">
        <div class="input-group mb-3">
            <input type="text" name="SearchString" class="form-control" placeholder="Search by name..." />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>
    
    <p><a asp-action="Create" class="btn btn-primary">Add New Student</a></p>
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Class</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Name</td>
                <td>@item.ClassName</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    <a asp-controller="Grades" asp-action="Create" asp-route-studentId="@item.Id" class="btn btn-sm btn-primary">Add Grade</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>