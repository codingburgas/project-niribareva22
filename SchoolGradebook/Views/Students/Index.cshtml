@model IEnumerable<SchoolGradebook.Models.Student>

<div class="container">
    <h2>Students</h2>
    <p><a asp-action="Create" class="btn btn-primary">Add New Student</a></p>
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Class</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Name</td>
                <td>@item.ClassName</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>