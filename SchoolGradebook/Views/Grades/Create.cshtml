@model SchoolGradebook.Models.Grade

<div class="container">
    <h2>Add Grade</h2>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        
        <input type="hidden" name="StudentId" value="@ViewBag.StudentId" />

        <div class="form-group mb-3">
            <label asp-for="Value" class="form-label">Grade (2.00 - 6.00)</label>
            <input asp-for="Value" type="number" step="0.01" class="form-control" required />
        </div>

        <div class="form-group mb-3">
            <label asp-for="Subject" class="form-label">Subject</label>
            <select asp-for="Subject" class="form-control" asp-items="ViewBag.SubjectId"></select>
        </div>

        <button type="submit" class="btn btn-success">Save Grade</button>
        <a asp-controller="Students" asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>