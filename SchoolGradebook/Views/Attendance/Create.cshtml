@model SchoolGradebook.Models.Attendance

<div class="container">
    <h2>Add Absence</h2>
    <form asp-action="Create">
        <input type="hidden" name="StudentId" value="@ViewBag.StudentId" />

        <div class="form-group mb-3">
            <label>Subject</label>
            <select name="SubjectId" class="form-control" asp-items="ViewBag.Subjects"></select>
        </div>

        <div class="form-group mb-3">
            <label>Date</label>
            <input type="date" name="Date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
        </div>

        <div class="form-group mb-3">
            <div class="form-check">
                <input type="checkbox" name="IsExcused" class="form-check-input" value="true" />
                <label class="form-check-label">Is Excused?</label>
            </div>
        </div>

        <button type="submit" class="btn btn-warning">Save Absence</button>
        <a asp-controller="Students" asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>